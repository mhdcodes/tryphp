---
import { Seo } from "astro-seo-meta";
import { site } from "../config";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="msvalidate.01" content="D1916A06C360E731C64F4EEA9FE4BC08" />
    <Seo
      title={site.title}
      description={site.description}
      keywords={[
        "PHP environment setup",
        "Install PHP easily",
        "Set up PHP in seconds",
        "Effortless PHP configuration",
        "PHP setup for developers",
        "Quick PHP environment install",
        "PHP development environment",
        "Automatic PHP setup",
        "Install latest PHP version",
        "Easy PHP installation guide",
        "PHP environment for beginners",
        "Fast PHP setup tool",
      ]}
      facebook={{
        image: "/cover.png",
        url: site.url,
        type: "website",
      }}
      twitter={{
        image: "/cover.png",
        site: "@mhdcode",
        card: "summary",
      }}
    />
  </head>
  <body
    class="bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-300"
  >
    <slot />
  </body>
</html>
